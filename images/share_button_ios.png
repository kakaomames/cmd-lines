                wplppprompt{display:block;}
                wplpppromptcontainer{
                    padding: 20px;
                    background: #fff;
                    box-sizing: border-box;
                    width: 450px;
                    position: fixed;
                    top: 10px;
                    left:calc(50% - 225px);
                    border:1px solid #dedddd;
                    z-index:100000000;
                    
                }
                wplppprompticon{
                    width: 20%;
                    float: left;
                    display: block;
                    margin: 0 auto;
                    text-align: left;
